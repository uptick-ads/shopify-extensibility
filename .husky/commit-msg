# Enforce conventional commit prefix
commit_msg=$(cat "$1")
pattern="^((Merge[ a-z-]* branch.*)|(Revert*)|((work|build|chore|ci|docs|feat|fix|perf|refactor|revert|style|test)(\(.*\))?!?: .*))"

if ! echo "$commit_msg" | grep -qE "$pattern"; then
  echo "\n❌ Commit message must start with a type prefix:"
  echo "   work|build|chore|ci|docs|feat|fix|perf|refactor|revert|style|test"
  echo "\n   Example: feat: add new feature"
  echo "   Example: fix(api): resolve timeout issue\n"
  exit 1
fi
